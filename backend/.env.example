# Copy this file to `.env.local` (gitignored) and put REAL values there.
# NEVER put real secrets in this .env.example — it is committed to git.

# --- NeonDB ---
# Pooled connection string (PgBouncer) — used at RUNTIME by the app + OCPP server.
DATABASE_URL='postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require'
# Direct connection string (no -pooler) — used ONLY for migrations (drizzle-kit).
DATABASE_URL_DIRECT='postgresql://USER:PASSWORD@ep-xxxxx.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require'

# --- Servers ---
HTTP_PORT=3000
OCPP_PORT=9220

# --- Auth ---
# Long random string used to sign/verify CPO console JWTs.
JWT_SECRET=CHANGE_ME_long_random_string

# --- Razorpay (set later) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
