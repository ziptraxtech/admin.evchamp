# ════════════════════════════════════════════════════════════════
#  admin_pay — environment example
#  Copy the BACKEND section into `backend/.env` before running the API.
#  (The backend loads `.env` via dotenv.)
# ════════════════════════════════════════════════════════════════

# ── NeonDB (Postgres) ──
# Pooled connection string (PgBouncer) — used at RUNTIME by the API + OCPP server.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/evchamp?sslmode=require"
# Direct connection string — used ONLY for migrations (drizzle-kit).
DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/evchamp?sslmode=require"

# ── Servers ──
HTTP_PORT=3000
OCPP_PORT=9220

# ── Auth ──
# Secret used to sign/verify CPO console JWTs. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-secret"

# ── Razorpay (set when wiring real payments) ──
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ════════════════════════════════════════════════════════════════
#  CONSOLE FRONTEND (static — console/)
#  The console reads these at runtime from `console/config.js`
#  (copy console/config.example.js → console/config.js), NOT from this file.
#  Listed here for reference / future framework migration:
# ════════════════════════════════════════════════════════════════
# API_BASE_URL=http://localhost:3000/api
# PAY_APP_URL=http://localhost:5601
